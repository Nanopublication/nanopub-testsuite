@prefix ex: <https://example.org/ns/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix npx: <http://purl.org/nanopub/x/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix orcid: <https://orcid.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .

sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  ex:RAXYq5rKz_YGb4SRnQGlLEXaG17mVIZNezkyme3n93HtU a ex:Concept;
    rdfs:label "a concept minted in a custom namespace" .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo orcid:0000-0002-1267-0234 .
}

sub:pubinfo {
  this: dct:created "2024-09-18T11:19:06.183Z"^^xsd:dateTime;
    dct:creator orcid:0000-0002-1267-0234;
    npx:introduces ex:RAXYq5rKz_YGb4SRnQGlLEXaG17mVIZNezkyme3n93HtU .
  
  sub:sig npx:hasAlgorithm "RSA";
    npx:hasPublicKey "";
    npx:hasSignature "";
    npx:hasSignatureTarget this:;
    npx:signedBy orcid:0000-0000-0000-0000 .
}
